---
import Layout from '../layouts/Layout.astro';
import StarCatalogue from '../components/StarCatalogue';
---

<Layout title="AstroBis 3D Stellar Atlas" description="Explore bright stars in 3D using real RA/Dec coordinates, distance scaling, spectral classes, luminosity proxies, and constellation guide lines.">
  <section class="page-hero page-hero-stars">
    <div class="hero-chip">Bright-star coordinate atlas</div>
    <h1>3D Stellar Atlas</h1>
    <p>
      Navigate a log-distance star field with real equatorial coordinates, spectral colors,
      constellation guides, physical proxies, and a compact H-R diagram.
    </p>
  </section>

  <StarCatalogue client:only="react" />
</Layout>
