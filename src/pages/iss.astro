---
import Layout from '../layouts/Layout.astro';
import ISSTracker from '../components/ISSTracker';
---

<Layout title="AstroBis ISS Mission Control" description="Track the International Space Station with CelesTrak TLE data, SGP4 propagation, a textured 3D Earth, orbit arc, and ground-track map.">
  <section class="page-hero page-hero-iss">
    <div class="hero-chip">CelesTrak TLE + SGP4 orbit propagation</div>
    <h1>ISS Mission Control</h1>
    <p>
      A live 3D Earth with geography, city lights, clouds, current station position, projected ground track,
      and orbital telemetry propagated from the latest available ISS TLE.
    </p>
  </section>

  <ISSTracker client:only="react" />
</Layout>
