---
import Layout from '../layouts/Layout.astro';
import ExoplanetExplorer from '../components/ExoplanetExplorer';
---

<Layout title="AstroBis Exoplanet Archive" description="Browse up to 4,000 exoplanets from the NASA Exoplanet Archive with measured parameters, stellar proxies, discovery-facility plots, and references.">
  <section class="page-hero page-hero-exo">
    <div class="hero-chip">NASA Exoplanet Archive TAP</div>
    <h1>Exoplanet Archive</h1>
    <p>
      Search and sort measured worlds from NASA's composite exoplanet table. Cards and plot views combine orbital data,
      stellar metadata, luminosity-derived habitable-zone proxies, discovery-facility counts, and archive references.
    </p>
  </section>

  <section style="padding:2.2rem 0 0;">
    <ExoplanetExplorer client:only="react" />
  </section>
</Layout>
