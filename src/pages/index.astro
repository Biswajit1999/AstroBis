---
import Layout from '../layouts/Layout.astro';
import StarfieldCanvas from '../components/StarfieldCanvas';
import StatsCounter from '../components/StatsCounter';
import APODCard from '../components/APODCard';
---

<Layout title="Home" description="An interactive astrophysics platform — explore the cosmos with real data and 3D simulations">

  <!-- ═══════════════════════════════ HERO ════════════════════════════════ -->
  <section style="
    position:relative; min-height:100vh;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    overflow:hidden; padding:6rem 1.5rem 4rem;
    text-align:center;
  ">
    <!-- Animated starfield canvas -->
    <StarfieldCanvas client:load />

    <!-- Nebula blobs -->
    <div style="position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(124,58,237,0.18) 0%,transparent 70%);top:-200px;left:-200px;pointer-events:none;animation:nebula-drift 14s ease-in-out infinite;" />
    <div style="position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(219,39,119,0.12) 0%,transparent 70%);bottom:-100px;right:-100px;pointer-events:none;animation:nebula-drift 18s ease-in-out infinite reverse;" />
    <div style="position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.10) 0%,transparent 70%);top:40%;left:60%;pointer-events:none;animation:nebula-drift 22s ease-in-out infinite;" />

    <!-- Hero content -->
    <div style="position:relative;z-index:10;max-width:900px;">
      <!-- Eyebrow with author -->
      <div style="
        display:inline-flex;align-items:center;gap:0.5rem;
        background:rgba(139,92,246,0.12);
        border:1px solid rgba(139,92,246,0.3);
        border-radius:50px; padding:0.4rem 1.1rem;
        font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
        color:#c4b5fd; margin-bottom:1.75rem;
      ">
        <span style="width:6px;height:6px;border-radius:50%;background:#a78bfa;animation:pulse-glow 2s ease-in-out infinite;display:inline-block;"></span>
        Interactive Astrophysics Platform &mdash; by Biswajit Jana @2026
      </div>

      <!-- Title -->
      <h1 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(3.2rem,9vw,7rem);
        font-weight:900; line-height:1.02;
        letter-spacing:-0.03em;
        margin-bottom:1.5rem;
        background:linear-gradient(135deg,#ffffff 0%,#e0c8ff 30%,#ec4899 70%,#f97316 100%);
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
        background-clip:text;
      ">
        Explore<br />the Cosmos
      </h1>

      <!-- Subtitle -->
      <p style="
        font-size:clamp(1rem,2.5vw,1.35rem);
        color:rgba(255,255,255,0.62);
        max-width:620px; margin:0 auto 2.5rem;
        line-height:1.7;
      ">
        Built by Biswajit Jana — real NASA data, full 3D solar-system simulation,
        and interactive exoplanet explorer in your browser.
      </p>

      <!-- CTAs -->
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;">
        <a href="/viewer" class="btn btn-primary" style="font-size:1rem;">
          🚀 Launch 3D Simulator
        </a>
        <a href="/exoplanets" class="btn btn-secondary" style="font-size:1rem;">
          🌍 Exoplanet Explorer
        </a>
      </div>

      <!-- Scroll indicator -->
      <div style="
        display:flex;flex-direction:column;align-items:center;
        color:rgba(255,255,255,0.25);font-size:0.75rem;gap:0.4rem;
        animation:float 2.5s ease-in-out infinite;
      ">
        <span>Scroll to explore</span>
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
          <rect x="1" y="1" width="14" height="22" rx="7" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
          <circle cx="8" cy="7" r="2.5" fill="rgba(255,255,255,0.3)">
            <animateTransform attributeName="transform" type="translate" values="0,0;0,10;0,0" dur="2.5s" repeatCount="indefinite"/>
          </circle>
        </svg>
      </div>
    </div>

    <!-- Floating planet decorations -->
    <div style="position:absolute;right:5%;top:20%;font-size:5rem;animation:float 4s ease-in-out infinite;opacity:0.18;pointer-events:none;filter:blur(1px);">🪐</div>
    <div style="position:absolute;left:4%;bottom:25%;font-size:3rem;animation:float 5s ease-in-out infinite 1s;opacity:0.14;pointer-events:none;filter:blur(1px);">🌌</div>
    <div style="position:absolute;right:12%;bottom:18%;font-size:2.5rem;animation:float 6s ease-in-out infinite 2s;opacity:0.12;pointer-events:none;">✨</div>
  </section>

  <!-- Section divider -->
  <div class="section-divider" />

  <!-- ═══════════════════════════════ STATS ═══════════════════════════════ -->
  <section style="padding:5rem 1rem;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(1.8rem,4vw,2.8rem);
        font-weight:900;margin-bottom:0.75rem;
        background:linear-gradient(135deg,#60a5fa,#a78bfa,#f0abfc);
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      ">
        The Universe by the Numbers
      </h2>
      <p style="color:rgba(255,255,255,0.45);font-size:0.95rem;max-width:480px;margin:0 auto;">
        The cosmos is vast beyond imagination. Here's a glimpse.
      </p>
    </div>
    <StatsCounter client:visible />
  </section>

  <div class="section-divider" />

  <!-- ═════════════════════════ FEATURES GRID ═════════════════════════════ -->
  <section style="padding:6rem 1.5rem;max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:3.5rem;">
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(1.8rem,4vw,2.8rem);
        font-weight:900;margin-bottom:0.75rem;
        color:#fff;
      ">
        What You Can <span style="background:linear-gradient(135deg,#a78bfa,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Explore</span>
      </h2>
      <p style="color:rgba(255,255,255,0.45);font-size:0.95rem;">
        From real-time NASA data to interactive 3D physics simulations.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
      {[
        {
          icon:'🌌',
          title:'3D Solar System',
          desc:'All 8 planets orbiting in real-time with Saturn\'s rings, Earth\'s moon, the asteroid belt, and a glowing corona sun. Click any planet for data.',
          tag:'Three.js + WebGL',
          tagCol:'#a78bfa',
          href:'/viewer',
          cta:'Open Simulator',
        },
        {
          icon:'🔭',
          title:'Exoplanet Explorer',
          desc:'Browse 5,700+ confirmed exoplanets from the NASA Exoplanet Archive. Filter, sort, and inspect orbital mechanics and habitability data.',
          tag:'NASA API',
          tagCol:'#f97316',
          href:'/exoplanets',
          cta:'Browse Planets',
        },
        {
          icon:'📸',
          title:'NASA APOD',
          desc:'Each day, NASA selects a stunning astronomy image. We fetch it live and display it with full scientific context — the universe daily.',
          tag:'Live Data',
          tagCol:'#ec4899',
          href:'#apod',
          cta:'See Today\'s Image ↓',
        },
        {
          icon:'📐',
          title:'Astrophysics Depth',
          desc:'Built on real astrophysics research. Accurate science, not simplified analogies — including stellar evolution, spectral types, and habitability indices.',
          tag:'Peer-reviewed',
          tagCol:'#60a5fa',
          href:'/about',
          cta:'About the Platform',
        },
      ].map(f => (
        <div class="card" style="display:flex;flex-direction:column;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">{f.icon}</div>
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:800;font-size:1.1rem;color:#fff;">{f.title}</h3>
            <span style={`font-size:0.65rem;font-weight:700;background:${f.tagCol}22;color:${f.tagCol};border:1px solid ${f.tagCol}44;border-radius:20px;padding:2px 8px;`}>{f.tag}</span>
          </div>
          <p style="font-size:0.85rem;color:rgba(255,255,255,0.55);line-height:1.65;flex:1;margin-bottom:1.25rem;">{f.desc}</p>
          <a href={f.href} style={`color:${f.tagCol};font-size:0.83rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:0.3rem;`}>
            {f.cta} →
          </a>
        </div>
      ))}
    </div>
  </section>

  <div class="section-divider" />

  <!-- ═════════════════════════════ APOD ═══════════════════════════════════ -->
  <section id="apod" style="padding:6rem 1.5rem;max-width:900px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(1.8rem,4vw,2.6rem);
        font-weight:900; margin-bottom:0.75rem;
        background:linear-gradient(135deg,#fbbf24,#f97316,#ec4899);
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      ">
        Today's View from NASA
      </h2>
      <p style="color:rgba(255,255,255,0.45);font-size:0.95rem;">
        The Astronomy Picture of the Day — curated by NASA scientists.
      </p>
    </div>
    <APODCard client:visible />
  </section>

  <div class="section-divider" />

  <!-- ════════════════════════════ CTA BOTTOM ══════════════════════════════ -->
  <section style="
    padding:8rem 1.5rem;text-align:center;
    position:relative;overflow:hidden;
  ">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(124,58,237,0.12) 0%,transparent 70%);pointer-events:none;" />
    <div style="position:relative;z-index:1;max-width:700px;margin:0 auto;">
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(2rem,5vw,3.5rem);
        font-weight:900;margin-bottom:1rem;
        background:linear-gradient(135deg,#fff 0%,#c4b5fd 50%,#ec4899 100%);
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      ">
        Ready to explore the universe?
      </h2>
      <p style="color:rgba(255,255,255,0.5);font-size:1.05rem;margin-bottom:2.5rem;line-height:1.7;">
        Zoom into Saturn's rings, click on Neptune, or browse 5,700 worlds beyond our solar system.
        No login. No download. Just science.
      </p>
      <a href="/viewer" class="btn btn-primary" style="font-size:1.1rem;padding:1rem 2.5rem;animation:pulse-glow 3s ease-in-out infinite;">
        🚀 Launch the 3D Simulator
      </a>
    </div>
  </section>

</Layout>
