---
import Layout from '../layouts/Layout.astro';
import ISSTracker from '../components/ISSTracker';
---

<Layout title="AstroBis ISS Mission Control" description="Track the International Space Station with live telemetry, a textured 3D Earth, orbit arc, and ground-track map.">
  <section class="page-hero page-hero-iss">
    <div class="hero-chip">Live ISS telemetry - 3 second refresh</div>
    <h1>ISS Mission Control</h1>
    <p>
      A live 3D Earth with geography, clouds, current station position, ground-track history,
      and orbital telemetry from the public ISS feed.
    </p>
  </section>

  <ISSTracker client:load />
</Layout>
