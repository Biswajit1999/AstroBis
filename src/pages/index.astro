---
import Layout from '../layouts/Layout.astro';
import StarfieldCanvas from '../components/StarfieldCanvas';
import StatsCounter from '../components/StatsCounter';
import APODCard from '../components/APODCard';

const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl.replace(/\/$/, '');
const withBase = (path: string) => path === '/' ? baseUrl : `${basePath}${path}`;

const missionTiles = [
  {
    index: '01',
    label: 'Solar System',
    value: 'Oort-scale',
    detail: 'Planets, dwarf planets, AU ruler, heliopause, and spherical Oort Cloud shells.',
    href: withBase('/viewer'),
  },
  {
    index: '02',
    label: 'Exoplanets',
    value: 'NASA snapshot',
    detail: 'Build-time Archive catalogue with source links, mission plots, and distribution charts.',
    href: withBase('/exoplanets'),
  },
  {
    index: '03',
    label: 'Small Bodies',
    value: 'Through 2050',
    detail: 'JPL close-approach data plus hyperbolic interstellar visitor context.',
    href: withBase('/neo'),
  },
  {
    index: '04',
    label: 'ISS Orbit',
    value: 'Live Earth',
    detail: 'Textured 3D Earth, orbit projection, telemetry, and ground track.',
    href: withBase('/iss'),
  },
];

const featureModules = [
  {
    code: 'AU',
    title: 'Solar System Atlas',
    desc: 'A compressed real-distance Solar System with planets, dwarf planets, moon counts, asteroid belt, trojans, Kuiper belt, heliopause, AU ruler, and Oort Cloud shells.',
    tag: 'Three.js + WebGL',
    tagCol: '#a78bfa',
    href: withBase('/viewer'),
    cta: 'Open Atlas',
  },
  {
    code: 'EXO',
    title: 'Exoplanet Explorer',
    desc: 'NASA Exoplanet Archive data with measured radius, mass, orbit, temperature, discovery method, facility counts, distribution plots, and source references.',
    tag: 'NASA Archive',
    tagCol: '#f97316',
    href: withBase('/exoplanets'),
    cta: 'Browse Planets',
  },
  {
    code: 'ISS',
    title: 'ISS Mission Control',
    desc: 'Track the station over a textured 3D Earth with live telemetry, orbit projection, cloud layer, and ground-track map.',
    tag: 'Live Orbit',
    tagCol: '#22c55e',
    href: withBase('/iss'),
    cta: 'Track ISS',
  },
  {
    code: 'NEO',
    title: 'Small-Body Watch',
    desc: 'Look ahead through 2050 using JPL close-approach data with distance filters, speed, size estimates, risk-proxy sorting, and interstellar visitor orbits.',
    tag: 'JPL CAD',
    tagCol: '#fb7185',
    href: withBase('/neo'),
    cta: 'Open Watch',
  },
  {
    code: 'HR',
    title: '3D Stellar Atlas',
    desc: 'Navigate bright stars using real RA/Dec coordinates, spectral colors, constellation guides, distance shells, and an H-R diagram.',
    tag: 'Star Data',
    tagCol: '#60a5fa',
    href: withBase('/stars'),
    cta: 'Open Atlas',
  },
  {
    code: 'APOD',
    title: 'NASA APOD',
    desc: 'Each day, NASA selects an astronomy image with scientific context. AstroBis keeps it alongside the live data tools.',
    tag: 'Daily NASA',
    tagCol: '#ec4899',
    href: '#apod',
    cta: 'See Today',
  },
];
---

<Layout title="Home" description="AstroBis is an interactive astronomy platform for realistic 3D space data, Oort-scale solar-system exploration, exoplanets, ISS tracking, small bodies, and star maps.">
  <section class="home-hero hero-scan">
    <StarfieldCanvas client:load />

    <div class="home-orbit-stage" aria-hidden="true">
      <span class="home-orbit-ring ring-a"></span>
      <span class="home-orbit-ring ring-b"></span>
      <span class="home-orbit-ring ring-c"></span>
      <span class="home-axis-line axis-x"></span>
      <span class="home-axis-line axis-y"></span>
    </div>

    <div class="home-hero-shell">
      <p class="home-eyebrow">
        <span></span>
        Interactive astronomy platform - by Biswajit Jana @2026
      </p>

      <h1 class="home-title">AstroBis</h1>

      <p class="home-subtitle">
        A browser-native space lab for realistic Solar System scale, live orbital tracking,
        future asteroid approaches, interstellar visitors, exoplanet discovery data, and a dimensional stellar atlas.
      </p>

      <div class="home-cta-row">
        <a href={withBase('/viewer')} class="btn btn-primary">
          Open Solar System Atlas
        </a>
        <a href={withBase('/exoplanets')} class="btn btn-secondary">
          Browse Exoplanets
        </a>
      </div>

      <div class="mission-deck" aria-label="AstroBis mission modules">
        {missionTiles.map(tile => (
          <a class="mission-tile" href={tile.href}>
            <span class="mission-index">{tile.index}</span>
            <span class="mission-label">{tile.label}</span>
            <strong>{tile.value}</strong>
            <small>{tile.detail}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <section class="home-section">
    <div class="section-intro">
      <p class="section-kicker">Reference values</p>
      <h2 class="section-heading gradient-text-cool">Catalogues and Cosmic Scale</h2>
      <p class="section-copy">
        Live-facing pages use build-time public-data snapshots where possible. Scale references are labelled separately from observed catalogues.
      </p>
    </div>
    <StatsCounter client:load />
  </section>

  <div class="section-divider"></div>

  <section class="home-section home-section-wide">
    <div class="section-intro">
      <p class="section-kicker">Mission modules</p>
      <h2 class="section-heading">
        What You Can <span class="gradient-text">Explore</span>
      </h2>
      <p class="section-copy">
        From the Oort Cloud to live orbital traffic, AstroBis keeps the useful science close to the surface.
      </p>
    </div>

    <div class="feature-grid">
      {featureModules.map(f => (
        <article class="feature-card">
          <div class="feature-card-top">
            <span class="feature-code">{f.code}</span>
            <span class="feature-tag" style={`--tag-color:${f.tagCol};`}>{f.tag}</span>
          </div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
          <a href={f.href} style={`--link-color:${f.tagCol};`}>
            {f.cta}
            <span aria-hidden="true">-&gt;</span>
          </a>
        </article>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <section id="apod" class="home-section home-section-narrow">
    <div class="section-intro">
      <p class="section-kicker">NASA APOD</p>
      <h2 class="section-heading gradient-text">Today's View from NASA</h2>
      <p class="section-copy">
        The Astronomy Picture of the Day, curated by NASA scientists.
      </p>
    </div>
    <APODCard client:visible />
  </section>

  <div class="section-divider"></div>

  <section class="home-final-cta">
    <div>
      <p class="section-kicker">Begin at 1 AU</p>
      <h2>Start with the Solar System</h2>
      <p>
        Open the AstroBis atlas, travel from Mercury to the Oort Cloud, then jump into exoplanets,
        live ISS telemetry, future asteroid approaches, and the stellar map.
      </p>
      <a href={withBase('/viewer')} class="btn btn-primary">
        Open the Solar System Atlas
      </a>
    </div>
  </section>
</Layout>
