---
import Layout from '../layouts/Layout.astro';
import NEOTracker from '../components/NEOTracker';
---

<Layout title="AstroBis Small-Body Watch" description="Track JPL close-approach objects through 2050 and interstellar visitor objects with distance, speed, size, energy, and hyperbolic-orbit context.">
  <section class="page-hero page-hero-neo">
    <div class="hero-chip">JPL SBDB close approaches + interstellar visitors</div>
    <h1>Small-Body And Visitor Watch</h1>
    <p>
      Search future Earth close approaches, adjust the distance horizon, inspect risk-proxy metrics,
      and compare known hyperbolic visitors such as 1I, 2I, and 3I/ATLAS.
    </p>
  </section>

  <section style="padding:2.2rem 0 0;">
    <NEOTracker client:only="react" />
  </section>
</Layout>
